{
  "name": "trading-decision-lab",
  "version": "0.7.0",
  "description": "Trading Decision Lab - professionelles Entscheidungszentrum (Web, Desktop, Android)",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:check": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "desktop": "electron .",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "android:init": "npm install @capacitor/android && npx cap add android",
    "android:sync": "npm run build && npx cap sync android",
    "android:open": "npx cap open android"
  },
  "build": {
    "appId": "de.schlichting.tradinglab",
    "productName": "Trading Decision Lab",
    "files": [
      "dist/**",
      "electron/**"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  },
  "dependencies": {
    "@capacitor/core": "^8.4.1",
    "axios": "^1.7.0",
    "chart.js": "^4.4.0",
    "lucide-vue-next": "^0.369.0",
    "node-cache": "^5.1.2",
    "pinia": "^2.2.0",
    "vue": "^3.4.0",
    "vue-chartjs": "^5.3.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@tailwindcss/forms": "^0.5.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "autoprefixer": "^10.4.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.1.0",
    "vue-tsc": "^1.8.0"
  }
}
